{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "EventsConnectionString": "Server=localhost;Database=EVENTS;User Id=sa;Password=TuPasswordFuerte123*;Encrypt=False;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "dev-super-secret-key-change-me",
    "Issuer": "pcua",
    "Audience": "pcua",
    "DurationInMinutes": 60
  },
  "Email": {
    "DefaultRecipientEmail": "your-email@gmail.com",
    "FromEmail": "your-email@gmail.com",
    "FromName": "Notification Service",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UserName": "your-email@gmail.com",
      "Password": "YOUR_GMAIL_APP_PASSWORD",
      "UseStartTls": true
    }
  },
  "AllowedHosts": "*",
  "Information": {
    "ApplicationCode": "DNET",
    "PathBase": "/api"
  },
  "MessageBroker": {
    "Host": "amqp://localhost:5672",
    "UserName": "guest",
    "Password": "guest"
  }
}
